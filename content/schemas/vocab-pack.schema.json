{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "vocab-pack.schema.json",
  "title": "Vocabulary Pack",
  "type": "object",
  "required": ["id", "title", "level", "topic", "words"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
      "description": "Unique kebab-case pack id, matches filename without extension."
    },
    "title": { "type": "string", "minLength": 1 },
    "level": { "type": "string", "enum": ["A1", "A2", "A2-B1", "B1", "B1-B2"] },
    "topic": { "type": "string", "minLength": 1 },
    "words": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/word" }
    }
  },
  "definitions": {
    "word": {
      "type": "object",
      "required": ["id", "pos", "meaning_en", "example_de", "example_en"],
      "additionalProperties": false,
      "properties": {
        "id": {
          "type": "string",
          "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$",
          "description": "Unique within the pack (and ideally globally): kebab-case of the lemma, e.g. 'der-loeffel'."
        },
        "pos": { "type": "string", "enum": ["noun", "verb", "adjective", "adverb", "other"] },
        "lemma": { "type": "string", "minLength": 1, "description": "Headword as shown in lists, e.g. 'Löffel' or 'fahren'." },
        "meaning_en": { "type": "string", "minLength": 1 },
        "example_de": { "type": "string", "minLength": 1 },
        "example_en": { "type": "string", "minLength": 1 },
        "tags": { "type": "array", "items": { "type": "string" } },

        "gender": { "type": "string", "enum": ["der", "die", "das"], "description": "Required for pos=noun." },
        "plural": { "type": "string", "description": "Required for pos=noun. Use '-' if no plural / plural-only marked separately." },

        "present_3sg": { "type": "string", "description": "Required for pos=verb, e.g. 'fährt'." },
        "praeteritum": { "type": "string", "description": "Required for pos=verb, e.g. 'fuhr'." },
        "perfekt": { "type": "string", "description": "Required for pos=verb, full form e.g. 'ist gefahren' or 'hat gemacht'." },
        "auxiliary": { "type": "string", "enum": ["haben", "sein"], "description": "Required for pos=verb." },
        "separable": { "type": "boolean", "description": "Optional for pos=verb; true if separable-prefix verb." },
        "government": { "type": "string", "description": "Optional case/preposition government, e.g. 'warten auf + Akk'." },

        "comparative": { "type": "string", "description": "Optional for pos=adjective, only if irregular, e.g. 'gut -> besser'." },
        "superlative": { "type": "string", "description": "Optional for pos=adjective, only if irregular, e.g. 'gut -> best-'." }
      },
      "allOf": [
        {
          "if": { "properties": { "pos": { "const": "noun" } } },
          "then": { "required": ["gender", "plural"] }
        },
        {
          "if": { "properties": { "pos": { "const": "verb" } } },
          "then": { "required": ["present_3sg", "praeteritum", "perfekt", "auxiliary"] }
        }
      ]
    }
  }
}
