{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "story.schema.json",
  "title": "Fill-in-the-blank Story",
  "type": "object",
  "required": ["id", "title", "level", "segments"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 1 },
    "level": { "type": "string", "enum": ["A1", "A2", "A2-B1", "B1", "B1-B2"] },
    "segments": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["type"],
        "properties": {
          "type": { "type": "string", "enum": ["text", "blank"] },
          "value": { "type": "string", "description": "Required for type=text." },
          "answer": { "type": "string", "description": "Required for type=blank." },
          "options": { "type": "array", "items": { "type": "string" }, "minItems": 2, "description": "Required for type=blank: multiple-choice options including the answer." }
        },
        "allOf": [
          { "if": { "properties": { "type": { "const": "text" } } }, "then": { "required": ["value"] } },
          { "if": { "properties": { "type": { "const": "blank" } } }, "then": { "required": ["answer", "options"] } }
        ],
        "additionalProperties": false
      }
    }
  }
}
