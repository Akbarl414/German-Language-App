{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "grammar-unit.schema.json",
  "title": "Grammar Unit",
  "type": "object",
  "required": ["id", "title", "level", "explanation", "exercises"],
  "additionalProperties": false,
  "properties": {
    "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
    "title": { "type": "string", "minLength": 1 },
    "level": { "type": "string", "enum": ["A1", "A2", "A2-B1", "B1", "B1-B2"] },
    "summary": { "type": "string", "description": "One-line description shown in the unit list." },
    "explanation": {
      "type": "object",
      "required": ["sections"],
      "additionalProperties": false,
      "properties": {
        "sections": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["heading", "body"],
            "additionalProperties": false,
            "properties": {
              "heading": { "type": "string", "minLength": 1 },
              "body": {
                "type": "string",
                "minLength": 1,
                "description": "Markdown-lite: plain text with \\n for paragraphs. Use pipe-delimited rows for a table, see 'table'."
              },
              "table": {
                "type": "object",
                "description": "Optional table rendered under the body text.",
                "required": ["headers", "rows"],
                "additionalProperties": false,
                "properties": {
                  "headers": { "type": "array", "items": { "type": "string" }, "minItems": 1 },
                  "rows": {
                    "type": "array",
                    "items": { "type": "array", "items": { "type": "string" } },
                    "minItems": 1
                  }
                }
              }
            }
          }
        }
      }
    },
    "exercises": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/definitions/exercise" }
    }
  },
  "definitions": {
    "exercise": {
      "type": "object",
      "required": ["id", "type", "prompt", "explanation"],
      "properties": {
        "id": { "type": "string", "pattern": "^[a-z0-9]+(-[a-z0-9]+)*$" },
        "type": {
          "type": "string",
          "enum": ["fill-blank", "multiple-choice", "reorder", "choose-form", "error-spot"]
        },
        "prompt": { "type": "string", "minLength": 1, "description": "Instruction/question text. For fill-blank/error-spot, includes the sentence with a blank marked '___' or the erroneous sentence." },
        "explanation": { "type": "string", "minLength": 1, "description": "Shown after answering, explains the correct answer." },

        "answer": { "type": "string", "description": "Required for fill-blank, choose-form (as the correct option text), error-spot (corrected sentence)." },
        "altAnswers": { "type": "array", "items": { "type": "string" }, "description": "Optional accepted alternative answers for fill-blank." },

        "options": { "type": "array", "items": { "type": "string" }, "minItems": 2, "description": "Required for multiple-choice and choose-form." },
        "answerIndex": { "type": "integer", "minimum": 0, "description": "Required for multiple-choice and choose-form: index into options." },

        "tokens": { "type": "array", "items": { "type": "string" }, "minItems": 2, "description": "Required for reorder: scrambled word/phrase tokens." },
        "answerOrder": { "type": "array", "items": { "type": "string" }, "minItems": 2, "description": "Required for reorder: tokens in correct order." }
      },
      "allOf": [
        {
          "if": { "properties": { "type": { "const": "fill-blank" } } },
          "then": { "required": ["answer"] }
        },
        {
          "if": { "properties": { "type": { "enum": ["multiple-choice", "choose-form"] } } },
          "then": { "required": ["options", "answerIndex"] }
        },
        {
          "if": { "properties": { "type": { "const": "reorder" } } },
          "then": { "required": ["tokens", "answerOrder"] }
        },
        {
          "if": { "properties": { "type": { "const": "error-spot" } } },
          "then": { "required": ["answer"] }
        }
      ],
      "additionalProperties": false
    }
  }
}
